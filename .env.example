# Solana RPC. Defaults to devnet if unset. Use a paid RPC for production
# (Helius, QuickNode, Triton) — public devnet is rate-limited.
VITE_SOLANA_RPC_URL=

# Mint address of the $BLOCK token. Leave blank until the token exists;
# the UI gracefully treats every wallet as a non-holder when unset.
VITE_BLOCK_TOKEN_MINT=

# (Future) Bags SDK credentials, if their SDK requires any.
# VITE_BAGS_API_KEY=
