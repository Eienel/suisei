# Auth token for the remote MCP endpoint at /api/mcp.
# Callers must send `Authorization: Bearer <token>`. Pick a long random
# string. Leaving this blank disables auth and exposes the endpoint
# publicly, so only do that for local testing.
SUISEI_MCP_TOKEN=

# --- Custom Sui JSON-RPC provider (optional) ---
# By default the toolkit uses the public Sui fullnode for each network.
# To run against a managed provider (Tatum, QuickNode, your own node, ...)
# set the per-network URL. This is also the hedge for the ~mid-2026
# deprecation of the public JSON-RPC endpoints.
# SUI_RPC_URL_TESTNET=https://sui-testnet.gateway.tatum.io
# SUI_RPC_URL_MAINNET=https://sui-mainnet.gateway.tatum.io
# SUI_RPC_URL_DEVNET=https://sui-devnet.gateway.tatum.io

# If the provider needs an API key, set it here. Default header is
# `x-api-key` (Tatum's recommended header). For Bearer-style providers,
# set SUI_RPC_API_KEY_HEADER=Authorization and prefix the value (e.g.
# "Bearer abc123").
# SUI_RPC_API_KEY=
# SUI_RPC_API_KEY_HEADER=x-api-key
