# --- Server-side (Vercel Function, never exposed to browser) ---
# Anthropic API key for the AI Builder Agent (/api/agent).
ANTHROPIC_API_KEY=

# --- Client-side (safe to expose; Vite inlines at build) ---
# Sui network: 'testnet' | 'devnet' | 'mainnet'
VITE_SUI_NETWORK=testnet

# Enoki — Mysten's zkLogin service.
# Sign up at https://portal.enoki.mystenlabs.com (free tier)
VITE_ENOKI_API_KEY=

# Google OAuth Web client ID — used by Enoki for "Sign in with Google".
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
# Authorized JS origin must include your Vercel domain.
VITE_ENOKI_GOOGLE_CLIENT_ID=

# After publishing the Move package (Phase 4): paste the package ID here.
VITE_WORLD_NFT_PACKAGE_ID=

# Walrus testnet endpoints (optional — sensible defaults used if blank).
# https://docs.walrus.site/usage/web-api.html
VITE_WALRUS_PUBLISHER_URL=
VITE_WALRUS_AGGREGATOR_URL=
