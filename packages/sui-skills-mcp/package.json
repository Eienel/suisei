{
  "name": "@suisei/sui-skills-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the Sui Stack as one-line tools for any agent. Suisei (suisei.dev) is a showcase app built on it.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js",
    "./http": "./dist/http.js",
    "./node": "./dist/node.js"
  },
  "bin": {
    "sui-skills-mcp": "dist/index.js",
    "sui-skills-mcp-serve": "dist/serve.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "serve": "node dist/serve.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sui",
    "blockchain",
    "claude",
    "anthropic",
    "agent",
    "tools"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@mysten/sui": "^1.45.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
