{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Suisei showcase",
  "type": "object",
  "required": ["projects"],
  "properties": {
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "tagline", "url"],
        "properties": {
          "name": { "type": "string" },
          "tagline": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "author": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  }
}
